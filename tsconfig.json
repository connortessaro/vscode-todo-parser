{
	"compilerOptions": {
		"module": "commonjs",
		"target": "es2020",
		"lib": ["ES2020"],
		"moduleResolution": "node",
		"esModuleInterop": true,
		"strict": true,
		"types": ["node", "mocha", "vscode"],
		"skipLibCheck": true,
		"outDir": "out",
		"sourceMap": true
	},
	"exclude": [
		"node_modules"
	]
}