{
    "name": "vscode-todo-parser",
    "version": "0.1.0",
    "description": "A VS Code extension that parses and manages TODO comments",
    "main": "dist/extension.js",
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "node ./out/test/runTest.js"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "^20.19.35",
        "@types/vscode": "^1.109.0",
        "@typescript-eslint/eslint-plugin": "^6.21.0",
        "@typescript-eslint/parser": "^6.21.0",
        "@vscode/test-electron": "^2.5.2",
        "chance": "^1.1.13",
        "eslint": "^8.57.1",
        "fs-extra": "^11.3.2",
        "glob": "^10.4.5",
        "typescript": "^5.9.3"
    },
    "engines": {
        "vscode": "^1.84.0"
    },
    "categories": [
        "Other"
    ],
    "license": "MIT",
    "dependencies": {
        "mocha": "^11.7.5",
        "typescript-collections": "^1.3.3",
        "vscode": "^1.1.37"
    }
}
